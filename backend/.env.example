PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/splitsvilla?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_secure_jwt_secret

# Client URLs (comma-separated)
CLIENT_URLS=http://localhost:8080,http://localhost:5173,https://your-render-app.onrender.com

# Email (Gmail SMTP)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_gmail_app_password

# Anthropic AI
ANTHROPIC_API_KEY=your_anthropic_api_key
